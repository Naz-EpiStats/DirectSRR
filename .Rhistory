study_data <- data.frame(
Deaths = c(4, 10, 1, 1, 0, 0, 121, 1, 2, 3, 1, 2, 14, 205, 0, 2, 16, 1, 1, 27), # Number of deaths, add data for each study
Total = c(634, 372, 123, 732, 189, 145, 3067, 507, 394, 1120, 618, 816, 1243, 8256, 806, 639, 4151, 139, 194, 4268), # Total population, add data for each study
Time = c(3, 3, 0.5, 1, 1, 1, 3, 10/12, 1, 0.5, 0.5, 0.5, 1, 22/12, 0.25, 0.5, 1, 0.5, 0.5, 1), # Time (years), add data for each study
Weight = c(0.010, 0.026, 0.001, 0.005, 0.002, 0.001, 0.273, 0.005, 0.004, 0.005, 0.003, 0.004, 0.039, 0.519, 0.004, 0.004, 0.033, 0.002, 0.002, 0.058), # Weight, add weight for each study
stringsAsFactors = FALSE)
# Calculate the annualized mortality rate for each study
study_data$Rate <- study_data$Deaths / (study_data$Time * study_data$Total)
# Calculate the weighted average annualized mortality rate for all studies
weighted_average_rate <- weighted.mean(study_data$Rate, study_data$Weight)
View(study_data)
cat("Annualized mortality rate for each study:\n")
print(study_data$Rate)
cat("Weighted average annualized mortality rate for all studies:", weighted_average_rate, "\n")
Weighted average annualized mortality rate for all studies: 0.01199257
