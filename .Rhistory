using("tidyverse","meta","dplyr", "devtools", "metafor")
library(metafor)
my_data <- data.frame(
group = c("Triple therapy vs LAMA/LABA", "ICS/LABA vs LABA", "Single ICS vs placebo"),
events_trial = c(61, 175, 176),
total_trial = c(10779, 9574, 8060),
events_control = c(66, 175, 215),
total_control = c(6522, 8576, 7842))
View(my_data)
model <- rma.mv(yi = c(log(events_trial / total_trial) - log(events_control / total_control)),
V = c(1 / events_trial + 1 / events_control),
mods = ~ group,
data = my_data)
# Calculate the between-subgroup interaction effect
interaction_result <- coef(summary(model))[3, "pval"]
# Output p for interaction
interaction_result
summary(model)
data(ThirdWave)
