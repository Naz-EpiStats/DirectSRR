library(tidyverse)
if (!require('tidyverse')) install.packages('tidyverse')
if (!require('igraph')) install.packages('igraph')
library(tidyverse)
library(igraph)
# Create vector of 17 team names
teams <- paste("Team", LETTERS[1:17])
# Create random graph with 17 nodes (teams)
# connected to 12 other nodes x 2 (home and away).
# Then convert to data frame and transform numeric
# identifiers into the actual team names.
matches <- sample_degseq(rep(12, length(teams)),
rep(12, length(teams)),
method = "simple.no.multiple") |>
as_data_frame() |>
rename(home = from, away = to) |>
mutate(across(c(home, away),
~ recode(.x, !!!setNames(teams, 1:17))))
View(matches)
version
