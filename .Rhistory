sm = "SMD",
fixed = FALSE,
random = TRUE,
method.tau = "REML",
hakn = TRUE,
title = "Third Wave Psychotherapies")
summary(m.gen)
update.meta(m.gen,
subgroup = RiskOfBias,
tau.common = FALSE)
meta::update.meta(m.gen,
